<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        tools:ignore="MissingConstraints">

    <FrameLayout
            android:id="@+id/fragment_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    <LinearLayout
            android:id="@+id/menu_view_parent"
            app:layout_constraintHeight_percent="0.25"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="0dp">

        <com.custom.arc.menu.SemiCircleMenuView
                android:id="@+id/menu_view"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <com.custom.arc.menu.CombinationView
                    android:id="@+id/shared_img_view"
                    android:text="设置"
                    android:textColor="@color/black"
                    android:background="@drawable/setting"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            <com.custom.arc.menu.CombinationView
                    android:id="@+id/voice_img_view"
                    android:text="寻车"
                    android:textColor="@color/black"
                    android:background="@drawable/findcar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            <com.custom.arc.menu.CombinationView
                    android:id="@+id/set_img_view"
                    android:text="控锁"
                    android:textColor="@color/black"
                    android:background="@drawable/control"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            <com.custom.arc.menu.CombinationView
                    android:id="@+id/user_img_view"
                    android:text="我的"
                    android:textColor="@color/colorBlue_3"
                    android:background="@drawable/user_my"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
        </com.custom.arc.menu.SemiCircleMenuView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>