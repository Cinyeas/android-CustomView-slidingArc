<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="MissingConstraints"
        tools:context=".MainActivity">

    <Button
            android:id="@+id/arc_menu_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="1、弧形菜单"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

    <Button
            android:id="@+id/poster_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2、海报编辑"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintTop_toBottomOf="@id/arc_menu_view"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="10dp"/>

    <Button
            android:id="@+id/battery_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="3、电池电量"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintTop_toBottomOf="@id/poster_view"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="10dp"/>

    <Button
            android:id="@+id/circle_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="4、欢迎页面倒计时"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintTop_toBottomOf="@id/battery_view"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="10dp"/>

    <Button
            android:id="@+id/light_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="5、灯光控制"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintTop_toBottomOf="@id/circle_view"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="10dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>