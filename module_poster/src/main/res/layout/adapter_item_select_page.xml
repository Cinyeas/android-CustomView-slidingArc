<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="MissingConstraints">

    <TextView
            android:id="@+id/select_item_tv"
            android:text="文字"
            android:textSize="10sp"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/select_item_img"
            app:layout_constraintLeft_toLeftOf="parent"/>

    <ImageView
            android:id="@+id/select_item_img"
            android:gravity="center"
            android:scaleType="center"
            android:layout_marginTop="6dp"
            android:background="@drawable/main_select_bg"
            app:layout_constraintTop_toBottomOf="@id/select_item_tv"
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

    <TextView
            android:id="@+id/select_item_value"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:background="@drawable/main_select_bg"
            app:layout_constraintTop_toBottomOf="@id/select_item_tv"
            android:layout_width="match_parent"
            android:layout_height="40dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>